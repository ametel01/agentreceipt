{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentReceipt Focus Report",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "session_id",
    "generated_at",
    "verdict",
    "process_contract",
    "reviewability",
    "agent_tasks",
    "recommended_next_commands",
    "top_reasons",
    "review_tasks",
    "changed_files",
    "reviewable_files",
    "suppressed_changes",
    "failed_gates",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": { "type": "integer" },
    "kind": { "type": "string", "const": "agentreceipt.session_focus" },
    "session_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "review_required",
        "block",
        "unverifiable"
      ]
    },
    "process_contract": {
      "type": "object",
      "properties": {
        "exit_code": { "type": "integer" },
        "meaning": { "type": "string" },
        "retryable": { "type": "boolean" }
      }
    },
    "reviewability": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ready", "partial", "blocked", "unverifiable"]
        },
        "blocking_gaps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "can_evaluate_integrity": { "type": "boolean" },
        "can_evaluate_code_quality": { "type": "boolean" },
        "requires_rerun_validation": { "type": "boolean" },
        "primary_blocker": { "type": "string" }
      }
    },
    "agent_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "priority": { "type": "string" },
          "kind": { "type": "string" },
          "gate": { "type": "string" },
          "path": { "type": "string" },
          "reason_code": { "type": "string" },
          "action": { "type": "string" },
          "question": { "type": "string" },
          "paths": { "type": "array", "items": { "type": "string" } },
          "symbols": { "type": "array", "items": { "type": "string" } },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "string" },
          "blocks_verdict": { "type": "boolean" },
          "source": { "type": "string" }
        }
      }
    },
    "recommended_next_commands": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "cwd": { "type": "string" },
          "argv": { "type": "array", "items": { "type": "string" } },
          "purpose": { "type": "string" },
          "reason_code": { "type": "string" },
          "task_ids": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "top_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "review_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3"]
          },
          "kind": { "type": "string" },
          "gate": { "type": "string" },
          "path": { "type": "string" },
          "reason_code": { "type": "string" },
          "question": { "type": "string" },
          "paths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "symbols": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": { "type": "string" },
          "source": { "type": "string" }
        }
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "action": { "type": "string" },
          "category": { "type": "string" },
          "sensitive": { "type": "boolean" },
          "dependency": { "type": "boolean" },
          "symbols": {
            "type": "array",
            "items": { "type": "string" }
          },
          "read_before_edit": { "type": "string" },
          "related_context_read": { "type": "string" },
          "tests_related": {
            "type": "array",
            "items": { "type": "string" }
          },
          "commands_touching_file": {
            "type": "array",
            "items": { "type": "string" }
          },
          "review_reasons": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "reviewable_files": {
      "type": "object",
      "properties": {
        "source_changes": { "type": "array", "items": { "type": "object" } },
        "test_changes": { "type": "array", "items": { "type": "object" } },
        "doc_changes": { "type": "array", "items": { "type": "object" } },
        "generated_changes": { "type": "array", "items": { "type": "object" } },
        "transient_changes": { "type": "array", "items": { "type": "object" } }
      }
    },
    "suppressed_changes": {
      "type": "array",
      "items": { "type": "object" }
    },
    "failed_gates": {
      "type": "array",
      "items": { "type": "object" }
    },
    "workspace_change_summary": {
      "type": "object",
      "properties": {
        "pre_existing_dirty_files": { "type": "array", "items": { "type": "string" } },
        "agent_touched_pre_existing_files": { "type": "array", "items": { "type": "string" } },
        "agent_created_changes": { "type": "array", "items": { "type": "string" } },
        "agent_modified_clean_files": { "type": "array", "items": { "type": "string" } },
        "final_diff_matches_workspace": { "type": "boolean" },
        "final_diff_matches_branch": { "type": "boolean" }
      }
    },
    "instruction_files": {
      "type": "array",
      "items": { "type": "object" }
    },
    "evidence_index": {
      "type": "array",
      "items": { "type": "object" }
    },
    "evaluator_signals": { "type": "object" },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
