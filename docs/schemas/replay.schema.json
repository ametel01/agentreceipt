{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentReceipt Replay Report",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "session_id",
    "generated_at",
    "source",
    "verification",
    "process_contract",
    "reviewability",
    "summary",
    "evaluator_signals",
    "quality_gates",
    "patch_summary",
    "policy_checks",
    "review_focus",
    "privacy",
    "claims",
    "outcome",
    "indexes",
    "query",
    "commands",
    "files",
    "gaps",
    "artifacts",
    "workspace_change_summary"
  ],
  "properties": {
    "schema_version": { "type": "integer" },
    "kind": { "type": "string", "const": "agentreceipt.session_replay" },
    "session_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source": { "type": "object" },
    "verification": { "type": "object" },
    "process_contract": {
      "type": "object",
      "properties": {
        "exit_code": { "type": "integer" },
        "meaning": { "type": "string" },
        "retryable": { "type": "boolean" }
      }
    },
    "reviewability": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ready", "partial", "blocked", "unverifiable"]
        },
        "blocking_gaps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "can_evaluate_integrity": { "type": "boolean" },
        "can_evaluate_code_quality": { "type": "boolean" },
        "requires_rerun_validation": { "type": "boolean" },
        "primary_blocker": { "type": "string" }
      }
    },
    "summary": { "type": "object" },
    "evaluator_signals": { "type": "object" },
    "quality_gates": { "type": "object" },
    "patch_summary": { "type": "object" },
    "policy_checks": {
      "type": "array",
      "items": { "type": "object" }
    },
    "review_focus": {
      "type": "array",
      "items": { "type": "object" }
    },
    "privacy": { "type": "object" },
    "claims": {
      "type": "array",
      "items": { "type": "object" }
    },
    "outcome": { "type": "object" },
    "indexes": {
      "type": "object",
      "properties": {
        "events": {
          "type": "object",
          "properties": {
            "count": { "type": "integer" },
            "artifact_ref": { "type": "string" },
            "sha256": { "type": "string" }
          }
        },
        "files": {
          "type": "object",
          "properties": {
            "count": { "type": "integer" },
            "artifact_ref": { "type": "string" },
            "sha256": { "type": "string" },
            "by_category": {
              "type": "object",
              "additionalProperties": { "type": "integer" }
            }
          }
        },
        "evidence": {
          "type": "object",
          "properties": {
            "count": { "type": "integer" },
            "artifact_ref": { "type": "string" },
            "sha256": { "type": "string" }
          }
        },
        "timeline_ranges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "range": { "type": "string" },
              "normalized_type": { "type": "string" },
              "count": { "type": "integer" },
              "evidence_refs": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "query": {
      "type": "object",
      "properties": {
        "full": { "type": "boolean" },
        "compact": { "type": "boolean" },
        "events": {
          "type": "array",
          "items": { "type": "string" }
        },
        "files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "selected_events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "seq": { "type": "integer" },
          "time": { "type": "string" },
          "source": { "type": "string" },
          "type": { "type": "string" },
          "normalized_type": { "type": "string" },
          "observed": { "type": "boolean" },
          "confidence": { "type": "string" },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "selected_files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "action": { "type": "string" },
          "sensitive": { "type": "boolean" },
          "dependency": { "type": "boolean" },
          "in_final_patch": { "type": "boolean" },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "selected_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ref": { "type": "string" },
          "type": { "type": "string" },
          "summary": { "type": "string" },
          "time": { "type": "string" },
          "command": { "type": "string" },
          "exit_code": { "type": "integer" },
          "path": { "type": "string" },
          "artifact": { "type": "string" },
          "confidence": { "type": "string" },
          "redacted": { "type": "boolean" }
        }
      }
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "seq": { "type": "integer" },
          "time": { "type": "string" },
          "source": { "type": "string" },
          "type": { "type": "string" },
          "normalized_type": { "type": "string" },
          "observed": { "type": "boolean" },
          "confidence": { "type": "string" },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "commands": {
      "type": "array",
      "items": { "type": "object" }
    },
    "files": {
      "type": "array",
      "items": { "type": "object" }
    },
    "evidence_index": {
      "type": "array",
      "items": { "type": "object" }
    },
    "instruction_files": {
      "type": "array",
      "items": { "type": "object" }
    },
    "risks": {
      "type": "array",
      "items": { "type": "object" }
    },
    "failed_command_details": {
      "type": "array",
      "items": { "type": "object" }
    },
    "gaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "verifier_tasks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "object" }
    },
    "workspace_change_summary": {
      "type": "object",
      "properties": {
        "pre_existing_dirty_files": { "type": "array", "items": { "type": "string" } },
        "agent_touched_pre_existing_files": { "type": "array", "items": { "type": "string" } },
        "agent_created_changes": { "type": "array", "items": { "type": "string" } },
        "agent_modified_clean_files": { "type": "array", "items": { "type": "string" } },
        "final_diff_matches_workspace": { "type": "boolean" },
        "final_diff_matches_branch": { "type": "boolean" }
      }
    }
  }
}
